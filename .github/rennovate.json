{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "labels": ["release-notes/dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group all kubernetes packages - tightly coupled, must be bumped atomically",
      "matchPackagePrefixes": [
        "k8s.io/",
        "sigs.k8s.io/"
      ],
      "groupName": "kubernetes packages"
    }
  ]
}