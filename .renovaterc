{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>cloud-orchestration/renovate-config"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)Makefile$",
        "(^|/)Dockerfile$",
        "(^|/)config.yml$"
      ],
      "matchStrings": [
        "(export|ARG|--build-arg=) *TERRAFORM_PROVIDER_VERSION *:?= *(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "terraform-provider",
      "versioningTemplate": "hashicorp",
      "depNameTemplate": "cloudfoundry/cloudfoundry"
    }
  ]
}
